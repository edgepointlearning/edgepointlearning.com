---
layout: 'layouts/page.njk'
---
{# BUG: https://github.com/trys/11ty-component-macro/issues/1 #}
{%- from "system/component.njk" import component -%}



{{ content | safe }}



<section class="relative">
  {% svg "waves/wave-2.svg", "wave-top -scale-y-100 fill-white" %}
  {% svg "waves/wave-8.svg", "wave-bot fill-slate-300" %}

  <article class="
    relative
    py-48 
    epl-prose-scale epl-prose-margin">
    <h2 class="!my-0 font-serif !font-normal !text-white text-center">{{ formIntro }}</h2>
  </article>

</section>



{# explore #}
<section class="bg-slate-300 pt-24 pb-16">
  <aside class="wrapper bg-slate-400 rounded-xl p-4">
    <header class="epl-prose-scale epl-prose-style">
      <h2 class="!mt-0 !mb-3 !text-slate-700">Explore</h2>
    </header>
    <div class="grid grid-cols-3 gap-12 mb-4">
      {%- for item in explore -%}
        {{ component('card.aside', { item: item }) }}
      {%- endfor -%}
    </div>
  </aside>
</section>